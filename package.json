{
  "name": "taygedo-auto-attendance-test1",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "action": "tsx src/action.ts",
    "local": "tsx src/runtimes/local-cli.ts",
    "worker:dev": "wrangler dev",
    "worker:build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "cloud:function:build": "node scripts/build-cloud-function.mjs",
    "cloud:function:pack": "node scripts/build-cloud-function.mjs --pack",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "dependencies": {
    "unstorage": "^1.17.5"
  },
  "cloudflare": {
    "bindings": {
      "TAYGEDO_ADMIN_TOKEN": {
        "description": "用于保护登录和手动签到接口。请填写独立的随机字符串，例如运行 `openssl rand -hex 32` 生成。"
      },
      "TAYGEDO_CREDENTIAL_KEY": {
        "description": "用于加密保存塔吉多密码。请填写另一段独立的随机字符串，例如运行 `openssl rand -hex 32` 生成。"
      }
    }
  }
}
